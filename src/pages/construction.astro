---
import ConstructionWeb from "@src/Images/ConstructionWeb.astro";
import Instagram from "@src/Images/icons/Instagram.astro";
import Youtube from "@src/Images/icons/Youtube.astro";
import Facebook from "@src/Images/icons/Facebook.astro";
import Linkedin from "@src/Images/icons/Linkedin.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Document</title>
  </head>
  <body>
    <section
      class="flex h-full items-center justify-center py-16 text-black-500"
    >
      <div class="mx-auto h-fit w-fit px-7 text-center">
        <h1 class="text-center text-[32px] font-bold leading-[38px]">
          Estamos construyendo algo increíble para ti
        </h1>
        <figure>
          <div class="mx-auto my-4 max-w-xl">
            <ConstructionWeb />
          </div>
          <figcaption class="flex flex-col items-center text-center">
            <p class="font-regular text-xl leading-xl">
              Pronto podrás explorar todo lo que tenemos para ofrecerte.
            </p>
            <p class="font-regular text-xl leading-xl">
              Mientras tanto, te invitamos a seguirnos en nuestras redes para no
              perderte ninguna novedad.
            </p>
            <ul class="mt-4 flex w-fit items-center justify-center gap-4">
              <li>
                <a
                  href="https://www.facebook.com/mmj.smart"
                  class="text-black-500 transition-all hover:text-primary-500"
                  ><Facebook /></a
                >
              </li>
              <li>
                <a
                  href="https://www.linkedin.com/company/mmj-smart"
                  class="text-black-500 transition-all hover:text-primary-500"
                  ><Linkedin /></a
                >
              </li>
              <li>
                <a
                  href="https://www.youtube.com/@mmjsmartelectronics4335"
                  class="text-black-500 transition-all hover:text-primary-500"
                >
                  <Youtube /></a
                >
              </li>
              <li>
                <a
                  href="https://www.instagram.com/mmj_smart_electronics/"
                  class="text-black-500 transition-all hover:text-primary-500"
                  ><Instagram /></a
                >
              </li>
            </ul>
          </figcaption>
        </figure>
      </div>
    </section>
  </body>
</html>
