---
import RobotError404 from "@src/Images/RobotError404.astro";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Página Movida</title>
  </head>
  <body>
    <section
      class="bg-gray-100 flex h-screen items-center justify-center"
      style="height: 100vh;"
    >
      <div
        class="bg-white mx-auto h-fit w-fit max-w-md rounded-lg p-8 px-7 text-center shadow-lg"
      >
        <div class="mb-4">
          <RobotError404 class="mx-auto w-24" />
        </div>
        <h2 class="mb-4 font-sans text-3xl font-bold text-black-500">
          ¡Atención!
        </h2>
        <p class="mb-4 text-lg font-medium leading-6">
          La ruta del aula virtual ha sido movida a <strong
            >aula.smartelectronics.com.pe</strong
          >.
        </p>
        <p class="mb-6 text-base font-light">
          Haz clic en el botón para acceder a la nueva ubicación.
        </p>
        <a
          href="https://aula.smartelectronics.com.pe/"
          class="mx-auto block w-full rounded-lg bg-primary-500 px-6 py-3 text-lg font-bold text-white-200 transition-colors hover:bg-primary-600"
        >
          Ir al aula virtual
        </a>
      </div>
    </section>
  </body>
</html>
