---
import type { GetStaticPaths } from "astro";
import { getEntry } from "astro:content";

// Layout
import Layout from "@src/layouts/Layout.astro";

// Components for Careers
import HeroCarrera from "@src/components/Carreras/Hero.astro";
import Courses from "@src/components/Carreras/Courses.astro";
import Plans from "@src/components/Carreras/Plans.astro";
import Ubication from "@src/components/Home/Ubication.astro";

// Components for Services
import HeroService from "@src/components/Servicios/Hero.astro";
import HighLights from "@src/components/Servicios/HighLights.astro";
import Services from "@src/components/Servicios/Services.astro";
import ExitCases from "@src/components/Servicios/ExitCases.astro";
// import OurProcess from "@src/components/Servicios/OurProcess.astro";

const { carrera } = Astro.params;

// Attempt to resolve as Career
let specificCarrer = await getEntry("carrers", `${carrera}`);
let isCareer = !!specificCarrer;
let isService = false;
let specificService = null;

if (!isCareer) {
  // Attempt to resolve as Service
  // Note: Service components expect 'service' param. We map 'carrera' logic to 'service'.
  specificService = await getEntry("services", `${carrera}`);
  if (specificService) {
    isService = true;
    // Inject service param for children components that rely on Astro.params.service
    Astro.params.service = carrera;
  }
}

// If neither, render 404 (or let Astro handle it, but explicit redirect is safer in this hybrid logic)
if (!isCareer && !isService) {
  return Astro.redirect("/404");
}

export const getStaticPaths = (() => {
  return [
    // Careers
    { params: { carrera: "embebido" } },
    { params: { carrera: "hardware" } },
    { params: { carrera: "software" } },
    { params: { carrera: "iot" } },
    { params: { carrera: "presencial" } },
    // Services (Mapped to carrera param for routing)
    { params: { carrera: "servicio-hardware" } },
    { params: { carrera: "servicio-software" } },
  ];
}) satisfies GetStaticPaths;

const pageTitle = isCareer ? "Carreras MMJ" : "Servicios MMJ";
---

<Layout title={pageTitle}>
  {
    isCareer && (
      <>
        <HeroCarrera />
        <Courses />
        {/* <Projects /> */}
        {/* <NextLaunch /> */}
        <Plans />
        <Ubication />
      </>
    )
  }

  {
    isService && (
      <>
        <HeroService />
        <HighLights />
        <Services />
        <ExitCases />
        {/* <OurProcess /> */}
        <Ubication />
      </>
    )
  }
</Layout>
